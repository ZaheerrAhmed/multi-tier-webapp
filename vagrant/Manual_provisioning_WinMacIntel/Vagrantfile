Vagrant.configure("2") do |config|
  # vagrant-hostmanager keeps /etc/hosts in sync across all VMs and the host
  config.hostmanager.enabled     = true
  config.hostmanager.manage_host = true

  # ── MySQL / MariaDB ──────────────────────────────────────────────────────────
  config.vm.define "db01" do |db01|
    db01.vm.box      = "generic/centos9s"
    db01.vm.hostname = "db01"
    db01.vm.network "private_network", ip: "192.168.56.15"
    db01.vm.provider "virtualbox" do |vb|
      vb.name   = "opsboard-db01"
      vb.memory = "600"
      vb.cpus   = 1
    end
  end

  # ── Memcached ────────────────────────────────────────────────────────────────
  config.vm.define "mc01" do |mc01|
    mc01.vm.box      = "generic/centos9s"
    mc01.vm.hostname = "mc01"
    mc01.vm.network "private_network", ip: "192.168.56.14"
    mc01.vm.provider "virtualbox" do |vb|
      vb.name   = "opsboard-mc01"
      vb.memory = "600"
      vb.cpus   = 1
    end
  end

  # ── RabbitMQ ─────────────────────────────────────────────────────────────────
  config.vm.define "rmq01" do |rmq01|
    rmq01.vm.box      = "generic/centos9s"
    rmq01.vm.hostname = "rmq01"
    rmq01.vm.network "private_network", ip: "192.168.56.13"
    rmq01.vm.provider "virtualbox" do |vb|
      vb.name   = "opsboard-rmq01"
      vb.memory = "600"
      vb.cpus   = 1
    end
  end

  # ── Tomcat / Application server ───────────────────────────────────────────────
  config.vm.define "app01" do |app01|
    app01.vm.box      = "generic/centos9s"
    app01.vm.hostname = "app01"
    app01.vm.network "private_network", ip: "192.168.56.12"
    app01.vm.provider "virtualbox" do |vb|
      vb.name   = "opsboard-app01"
      # 800 MB keeps Tomcat + Maven build within safe limits on this VM
      vb.memory = "800"
      vb.cpus   = 1
    end
  end

  # ── Nginx / Reverse proxy (Ubuntu) ───────────────────────────────────────────
  config.vm.define "web01" do |web01|
    web01.vm.box      = "ubuntu/jammy64"
    web01.vm.hostname = "web01"
    web01.vm.network "private_network", ip: "192.168.56.11"
    web01.vm.provider "virtualbox" do |vb|
      vb.name   = "opsboard-web01"
      vb.memory = "800"
      vb.cpus   = 1
    end
  end

end
